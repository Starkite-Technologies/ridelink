{
  "expo": {
    "name": "RideLink",
    "slug": "ridelink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow RideLink to share your location only while you operate an active passenger trip."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "RideLink uses your photos for Driver identity and vehicle verification.",
          "cameraPermission": "RideLink uses your camera for Driver selfie and vehicle verification.",
          "microphonePermission": false
        }
      ]
    ]
  }
}
